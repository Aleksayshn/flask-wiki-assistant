SECRET_KEY=dev-secret-key
FLASK_HOST=0.0.0.0
FLASK_PORT=8888

MYSQL_CACHE_ENABLED=false
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=wiki_cache
MYSQL_USER=wiki_user
MYSQL_PASSWORD=wiki_password

REMOTE_EXECUTION_ENABLED=false

